# ==========================
# Ambiente: DESENVOLVIMENTO
# ==========================

# URL base da API para ambiente de desenvolvimento (backend rodando localmente)
REACT_APP_API_BASE_URL=http://localhost:8000/api/
REACT_APP_ENVIRONMENT=development

# Observação:
# Esse modo usa a API local. Certifique-se de que o backend esteja rodando na porta 8000.


# =======================
# Ambiente: PRODUÇÃO
# =======================
# Quando for subir para produção, descomentar as linhas abaixo e comentar as acima:

# REACT_APP_API_BASE_URL=https://cargafacil.com/api/
# REACT_APP_ENVIRONMENT=production

# IMPORTANTE:
# 1. Executar `npm run build` após alterar para produção.
# 2. O build gerado em `build/` será o que devo subir para o servidor.
# 3. Verificar se o backend também está configurado com HTTPS e domínio correto.
